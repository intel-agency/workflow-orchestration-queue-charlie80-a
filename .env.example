# OS-APOW Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# Required Configuration
# ===========================================

# GitHub Personal Access Token or App Token
# Required for: All services
# Scopes needed: repo, read:org, write:discussion
GITHUB_TOKEN=your_github_token_here

# GitHub Webhook Secret
# Required for: Notifier service
# Set this in your GitHub App/Webhook configuration
WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Organization Name
# Required for: Sentinel service
GITHUB_ORG=your_org_name

# GitHub Repository Name
# Required for: Sentinel service
GITHUB_REPO=your_repo_name

# ===========================================
# Optional Configuration
# ===========================================

# Sentinel Bot Login (GitHub username of the bot account)
# Enables assign-then-verify distributed locking
SENTINEL_BOT_LOGIN=

# Polling interval in seconds (default: 60)
POLL_INTERVAL=60

# Maximum backoff in seconds on rate limits (default: 960)
MAX_BACKOFF=960

# Heartbeat interval in seconds (default: 300 / 5 minutes)
HEARTBEAT_INTERVAL=300

# Subprocess timeout in seconds (default: 5700 / 95 minutes)
SUBPROCESS_TIMEOUT=5700

# Path to shell bridge script
SHELL_BRIDGE_PATH=./scripts/devcontainer-opencode.sh

# Notifier service host (default: 0.0.0.0)
NOTIFIER_HOST=0.0.0.0

# Notifier service port (default: 8000)
NOTIFIER_PORT=8000

# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file - it contains secrets!
#
# Quick setup:
#   cp .env.example .env
#   # Edit .env with your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# SHARED AUTHENTICATION (Required by all services)
# -----------------------------------------------------------------------------

# GitHub API token for repository access
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
# [REQUIRED]
GITHUB_TOKEN=YOUR_VALUE_HERE

# GitHub Personal Access Token for MCP GitHub server
# Falls back to GITHUB_TOKEN if not set
# [OPTIONAL]
# GITHUB_PERSONAL_ACCESS_TOKEN=

# ZhipuAI API key for GLM model access
# Get your key at: https://open.bigmodel.cn/
# [REQUIRED]
ZHIPU_API_KEY=YOUR_VALUE_HERE

# Kimi/Moonshot API key for alternative model access
# Get your key at: https://platform.moonshot.cn/
# [OPTIONAL]
# KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY=

# -----------------------------------------------------------------------------
# SENTINEL SERVICE (Polling Service)
# -----------------------------------------------------------------------------

# Target repository in 'owner/repo' format
# Example: intel-agency/workflow-orchestration-queue-charlie80-a
# [REQUIRED]
GITHUB_REPO=YOUR_VALUE_HERE

# GitHub login of the sentinel bot account
# Example: sentinel-bot[bot]
# [REQUIRED]
SENTINEL_BOT_LOGIN=YOUR_VALUE_HERE

# Unique identifier for this sentinel instance
# Example: sentinel-001, prod-sentinel-primary
# [REQUIRED]
SENTINEL_ID=YOUR_VALUE_HERE

# Seconds between polling cycles
# [OPTIONAL] Default: 60
# POLL_INTERVAL=60

# Maximum backoff seconds on errors (exponential backoff cap)
# [OPTIONAL] Default: 300
# MAX_BACKOFF=300

# Seconds between heartbeat checks
# [OPTIONAL] Default: 300
# SENTINEL_HEARTBEAT_INTERVAL=300

# Timeout for subprocess operations in seconds
# [OPTIONAL] Default: 1800 (30 minutes)
# SUBPROCESS_TIMEOUT=1800

# Daily API budget limit in USD
# [OPTIONAL] Default: 10.0
# DAILY_BUDGET_LIMIT=10.0

# -----------------------------------------------------------------------------
# NOTIFIER SERVICE (Webhook Listener)
# -----------------------------------------------------------------------------

# Secret for validating webhook payloads
# Generate with: openssl rand -hex 32
# Minimum length: 16 characters
# [REQUIRED]
WEBHOOK_SECRET=YOUR_VALUE_HERE

# Port for webhook listener
# [OPTIONAL] Default: 8080
# GITHUB_WEBHOOK_PORT=8080

# GitHub App ID for authentication (if using GitHub App)
# [OPTIONAL]
# GITHUB_APP_ID=

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# [OPTIONAL] Default: INFO
# LOG_LEVEL=INFO

# Deployment environment: development, staging, production, test
# [OPTIONAL] Default: development
# ENVIRONMENT=development

# =============================================================================
# SETUP CHECKLIST
# =============================================================================
# [ ] Copy this file to .env: cp .env.example .env
# [ ] Set GITHUB_TOKEN with your GitHub PAT
# [ ] Set ZHIPU_API_KEY with your ZhipuAI key
# [ ] Set GITHUB_REPO to your target repository
# [ ] Set SENTINEL_BOT_LOGIN to your bot's GitHub login
# [ ] Set SENTINEL_ID to a unique identifier
# [ ] Set WEBHOOK_SECRET (generate with: openssl rand -hex 32)
# [ ] Run validation: pwsh scripts/validate-env.ps1
# [ ] Verify .env is in .gitignore (should be already)
# =============================================================================
